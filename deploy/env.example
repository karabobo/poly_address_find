# pm-robot wallet research environment

PM_ROBOT_HOME=/opt/pm-robot
PM_ROBOT_DB_PATH=/opt/pm-robot/data/pm_robot.sqlite
PM_ROBOT_RATE_LIMIT_DB_PATH=/opt/pm-robot/data/api_rate_limits.sqlite
PM_ROBOT_CANDIDATE_ADDRESSES=/opt/pm-robot/data/candidate_addresses.csv
PM_ROBOT_LOG_DIR=/opt/pm-robot/logs
PM_ROBOT_BACKUP_DIR=/opt/pm-robot/backups
PM_ROBOT_ARCHIVE_DIR=/opt/pm-robot/data/parquet
PM_ROBOT_REQUIRED_RUNTIME_HEARTBEATS=loop_discovery_leaderboard,loop_discovery_activity,loop_rtds_discovery,loop_wallet_screen_planner,loop_wallet_screen_worker_0,loop_wallet_screen_worker_1,loop_wallet_screen_worker_2,loop_wallet_level_control,loop_wallet_history_planner,loop_wallet_history_worker_0,loop_wallet_history_worker_1,loop_wallet_history_worker_2,loop_wallet_l6_validation_worker,loop_maintenance
PM_ROBOT_RUNTIME_HEARTBEAT_MAX_AGE_SECONDS=21600

# Set this before enabling the web console.
PM_ROBOT_UI_TOKEN=
