# pm-robot server environment

PM_ROBOT_HOME=/opt/pm-robot
PM_ROBOT_MODE=research

PM_ROBOT_DB_PATH=/opt/pm-robot/data/pm_robot.sqlite
PM_ROBOT_POLICY_PATH=/opt/pm-robot/config/leader_scoring_policy.json
PM_ROBOT_CANDIDATE_ADDRESSES=/opt/pm-robot/data/candidate_addresses.csv
PM_ROBOT_REVIEW_PATH=/opt/pm-robot/reports/pm_robot_review_queue.csv
PM_ROBOT_PAPER_LEDGER=/opt/pm-robot/data/paper_ledger.jsonl
PM_ROBOT_LOG_DIR=/opt/pm-robot/logs
PM_ROBOT_BACKUP_DIR=/opt/pm-robot/backups
PM_ROBOT_PAPER_BANKROLL_USD=2000

# Optional Google Drive offsite backups. Configure rclone so this remote points
# at the Drive folder used for pm-robot backups, then enable the timer.
PM_ROBOT_GDRIVE_REMOTE=
PM_ROBOT_GDRIVE_RETENTION_DAYS=30
PM_ROBOT_GDRIVE_ZSTD_LEVEL=10

# Set this before enabling the web console.
PM_ROBOT_UI_TOKEN=
