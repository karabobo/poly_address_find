PM_ROBOT_HOME=/app
# Host-side persistent storage root used by Docker bind mounts.
PM_ROBOT_STORAGE_ROOT=/volume1/poly_data/pmbot

PM_ROBOT_DB_PATH=/app/data/pm_robot.sqlite
# Tiny cross-container coordination DB, isolated from long wallet-data writes.
PM_ROBOT_RATE_LIMIT_DB_PATH=/app/data/api_rate_limits.sqlite
PM_ROBOT_RATE_LIMIT_LOCK_TIMEOUT_SECONDS=10
PM_ROBOT_CANDIDATE_ADDRESSES=/app/data/candidate_addresses.csv
PM_ROBOT_LOG_DIR=/app/logs
PM_ROBOT_BACKUP_DIR=/app/backups
PM_ROBOT_MAINTENANCE_KEEP_BACKUPS=0

PM_ROBOT_UI_TOKEN=

# Stable outbound proxy endpoint. Set HTTP(S)_PROXY to the NAS host address
# reachable from this Docker network; HAProxy keeps primary/secondary routing
# behind that unchanged address.
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=127.0.0.1,localhost
PM_ROBOT_PROXY_LOCAL_HOST=0.0.0.0
PM_ROBOT_PROXY_LOCAL_PORT=18082
PM_ROBOT_PROXY_REMOTE_HOST=127.0.0.1
PM_ROBOT_PROXY_REMOTE_PORT=18081
PM_ROBOT_PROXY_HEALTHCHECK_TARGET=ws-live-data.polymarket.com:443
PM_ROBOT_VPS_KNOWN_HOSTS_PATH=/ssh/known_hosts
PM_ROBOT_PROXY_PRIMARY_VPS_USER=
PM_ROBOT_PROXY_PRIMARY_VPS_HOST=
PM_ROBOT_PROXY_PRIMARY_TUNNEL_PORT=18083
PM_ROBOT_PROXY_SECONDARY_VPS_USER=
PM_ROBOT_PROXY_SECONDARY_VPS_HOST=
PM_ROBOT_PROXY_SECONDARY_TUNNEL_PORT=18084

# Health requires all long-running loops to report fresh runtime heartbeats.
PM_ROBOT_REQUIRED_RUNTIME_HEARTBEATS=loop_discovery_leaderboard,loop_discovery_activity,loop_rtds_discovery,loop_wallet_screen_planner,loop_wallet_screen_worker_0,loop_wallet_screen_worker_1,loop_wallet_screen_worker_2,loop_wallet_level_control,loop_wallet_history_planner,loop_wallet_history_worker_0,loop_wallet_history_worker_1,loop_wallet_history_worker_2,loop_wallet_l6_validation_worker,loop_maintenance
PM_ROBOT_RUNTIME_HEARTBEAT_MAX_AGE_SECONDS=900
# The polling discovery loop runs hourly; fast queues retain the 15-minute default.
PM_ROBOT_RUNTIME_HEARTBEAT_MAX_AGE_OVERRIDES=loop_discovery_leaderboard:7200,loop_discovery_activity:7200

# L0-L6 wallet funnel. Screening is cheap and broad; deeper history reads are
# admitted only after the preceding level and stored directly in Parquet.
PM_ROBOT_WALLET_SCREEN_PLANNER_INTERVAL=180
PM_ROBOT_WALLET_SCREEN_WORKER_INTERVAL=60
PM_ROBOT_WALLET_SCREEN_ACTIVE_INTERVAL=30
PM_ROBOT_WALLET_SCREEN_PLANNER_LIMIT=24
PM_ROBOT_WALLET_SCREEN_MAX_ACTIVE_JOBS=72
PM_ROBOT_WALLET_SCREEN_RESCREEN_AFTER_SECONDS=604800
PM_ROBOT_WALLET_SCREEN_SHARD_COUNT=3
PM_ROBOT_WALLET_SCREEN_WORKER_LIMIT=2
PM_ROBOT_WALLET_SCREEN_LEASE_SECONDS=600

PM_ROBOT_RESEARCH_CONTROL_INTERVAL=180
PM_ROBOT_RESEARCH_CONTROL_ACTIVE_INTERVAL=30
PM_ROBOT_WALLET_HISTORY_PLANNER_LIMIT=12
PM_ROBOT_WALLET_HISTORY_MAX_ACTIVE_JOBS=36
PM_ROBOT_WALLET_HISTORY_LIGHT_REFRESH_SECONDS=2592000
PM_ROBOT_WALLET_HISTORY_DEEP_REFRESH_SECONDS=604800
PM_ROBOT_WALLET_HISTORY_SHARD_COUNT=3
PM_ROBOT_WALLET_HISTORY_WORKER_INTERVAL=60
PM_ROBOT_WALLET_HISTORY_ACTIVE_INTERVAL=30
PM_ROBOT_WALLET_HISTORY_WORKER_LIMIT=1
PM_ROBOT_WALLET_HISTORY_LEASE_SECONDS=1800
PM_ROBOT_WALLET_HISTORY_REQUEST_SLEEP=0.05
PM_ROBOT_WALLET_LEVEL_MIN_COHORT_SIZE=20
PM_ROBOT_WALLET_LEVEL_TIMEOUT_MIN_COHORT_SIZE=5
PM_ROBOT_WALLET_LEVEL_MAX_WAIT_SECONDS=3600
PM_ROBOT_WALLET_LEVEL_L3_FRACTION=0.25
PM_ROBOT_WALLET_LEVEL_L4_FRACTION=0.20
PM_ROBOT_WALLET_LEVEL_L5_FRACTION=0.10
PM_ROBOT_WALLET_LEVEL_L3_MAX_PROMOTIONS=12
PM_ROBOT_WALLET_LEVEL_L4_MAX_PROMOTIONS=6
PM_ROBOT_WALLET_LEVEL_L5_MAX_PROMOTIONS=2

# L6 independently rechecks only the small current L5/L6 set. Warning or fail
# remains L5; only a pass advances to L6.
PM_ROBOT_WALLET_L6_PLANNER_LIMIT=5
PM_ROBOT_WALLET_L6_MAX_ACTIVE_JOBS=10
PM_ROBOT_WALLET_L6_REFRESH_SECONDS=1209600
PM_ROBOT_WALLET_L6_SHARD_COUNT=1
PM_ROBOT_WALLET_L6_WORKER_INTERVAL=300
PM_ROBOT_WALLET_L6_ACTIVE_INTERVAL=60
PM_ROBOT_WALLET_L6_WORKER_LIMIT=1
PM_ROBOT_WALLET_L6_LEASE_SECONDS=1800
PM_ROBOT_WALLET_L6_REQUEST_SLEEP=0.05

# High-quality discovery loop: official category leaderboards + whale-size trades.
PM_ROBOT_DISCOVERY_LOOP_INTERVAL=3600
PM_ROBOT_DISCOVERY_LEADERBOARD_METRICS=
PM_ROBOT_DISCOVERY_LEADERBOARD_WINDOWS=
PM_ROBOT_DISCOVERY_LEADERBOARD_CATEGORIES=OVERALL,POLITICS,SPORTS,CRYPTO
PM_ROBOT_DISCOVERY_LEADERBOARD_TIME_PERIODS=WEEK,MONTH
PM_ROBOT_DISCOVERY_LEADERBOARD_ORDER_BYS=PNL,VOL
PM_ROBOT_DISCOVERY_LEADERBOARD_V1_LIMIT=50
PM_ROBOT_DISCOVERY_LEADERBOARD_V1_PAGES=1
PM_ROBOT_DISCOVERY_ACTIVITY_PAGES=3
PM_ROBOT_DISCOVERY_ACTIVITY_PAGE_LIMIT=100
PM_ROBOT_DISCOVERY_ACTIVITY_MIN_TRADE_FILTER_USDC=500
PM_ROBOT_DISCOVERY_ACTIVITY_MAX_CANDIDATES=150
PM_ROBOT_DISCOVERY_ACTIVITY_SLEEP=0.05

# Real-time activity trade stream. Keeps discovery event-driven between polling cycles.
PM_ROBOT_RTDS_ENDPOINT=wss://ws-live-data.polymarket.com
PM_ROBOT_RTDS_MIN_TRADE_USDC=1
PM_ROBOT_RTDS_BATCH_SIZE=100
PM_ROBOT_RTDS_FLUSH_INTERVAL=10
PM_ROBOT_RTDS_PING_INTERVAL=5
PM_ROBOT_RTDS_RECEIVE_TIMEOUT=1
PM_ROBOT_RTDS_MAX_IDLE_SECONDS=300
PM_ROBOT_RTDS_RECONNECT_SLEEP=5
PM_ROBOT_RTDS_MAX_RUNTIME_SECONDS=0
PM_ROBOT_RTDS_MAX_RECONNECTS=0

# Passive checkpoint keeps allocated WAL space reusable without stopping writers.
# Physical shrinking remains an explicit low-traffic maintenance command.
PM_ROBOT_MAINTENANCE_INTERVAL=900
PM_ROBOT_MAINTENANCE_START_DELAY=300
PM_ROBOT_MAINTENANCE_WAL_CHECKPOINT=passive
PM_ROBOT_MAINTENANCE_REPORT_PATH=/app/reports/maintenance_status.json
PM_ROBOT_MAINTENANCE_FAILED_JOB_COOLDOWN_SECONDS=21600
PM_ROBOT_MAINTENANCE_RUNTIME_HEARTBEAT_DAYS=30
PM_ROBOT_MAINTENANCE_CLEANUP_BATCH_LIMIT=500
PM_ROBOT_WALLET_HISTORY_GC_ENABLED=1
PM_ROBOT_WALLET_HISTORY_GC_MIN_AGE_SECONDS=2592000
PM_ROBOT_WALLET_HISTORY_GC_KEEP_PER_WALLET=1
PM_ROBOT_WALLET_HISTORY_GC_LIMIT=500
# Fast metadata audit runs before GC. Full checksums stay opt-in because they
# read every Parquet byte; old uncatalogued files are removed conservatively.
PM_ROBOT_WALLET_HISTORY_AUDIT_ENABLED=1
PM_ROBOT_WALLET_HISTORY_AUDIT_VERIFY_CHECKSUMS=0
PM_ROBOT_WALLET_HISTORY_AUDIT_ORPHAN_MIN_AGE_SECONDS=604800
PM_ROBOT_WALLET_HISTORY_AUDIT_ORPHAN_LIMIT=500
PM_ROBOT_WALLET_HISTORY_AUDIT_DELETE_ORPHANS=1
PM_ROBOT_ARCHIVE_DIR=/app/data/parquet
