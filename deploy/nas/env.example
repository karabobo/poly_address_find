PM_ROBOT_HOME=/app
PM_ROBOT_MODE=research
# Host-side persistent storage root used by Docker bind mounts.
PM_ROBOT_STORAGE_ROOT=

PM_ROBOT_DB_PATH=/app/data/pm_robot.sqlite
# Tiny cross-container coordination DB, isolated from long wallet-data writes.
PM_ROBOT_RATE_LIMIT_DB_PATH=/app/data/api_rate_limits.sqlite
PM_ROBOT_RATE_LIMIT_LOCK_TIMEOUT_SECONDS=10
PM_ROBOT_POLICY_PATH=/app/config/leader_scoring_policy.json
PM_ROBOT_CANDIDATE_ADDRESSES=/app/data/candidate_addresses.csv
PM_ROBOT_REVIEW_PATH=/app/reports/pm_robot_review_queue.csv
PM_ROBOT_PAPER_LEDGER=/app/data/paper_ledger.jsonl
PM_ROBOT_LOG_DIR=/app/logs
PM_ROBOT_BACKUP_DIR=/app/backups
PM_ROBOT_PAPER_BANKROLL_USD=2000

PM_ROBOT_GDRIVE_REMOTE=
PM_ROBOT_GDRIVE_RETENTION_DAYS=30
PM_ROBOT_GDRIVE_ZSTD_LEVEL=10

# Scheduled full-database backups are opt-in while the storage layout is evolving.
PM_ROBOT_SCHEDULED_BACKUP_ENABLED=0
PM_ROBOT_BACKUP_INTERVAL=86400
PM_ROBOT_BACKUP_START_DELAY=600
PM_ROBOT_MAINTENANCE_KEEP_BACKUPS=0

PM_ROBOT_UI_TOKEN=

# Outbound proxy through the VPS HTTP CONNECT tunnel. Set HTTP(S)_PROXY to
# the NAS host address that is reachable from this Docker network.
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=127.0.0.1,localhost
PM_ROBOT_PROXY_LOCAL_HOST=0.0.0.0
PM_ROBOT_PROXY_LOCAL_PORT=18082
PM_ROBOT_PROXY_REMOTE_HOST=127.0.0.1
PM_ROBOT_PROXY_REMOTE_PORT=18081
PM_ROBOT_VPS_USER=root
PM_ROBOT_VPS_HOST=

# Ordered research control cycle plus asynchronous wallet evidence workers.
PM_ROBOT_RESEARCH_CONTROL_INTERVAL=300
PM_ROBOT_RESEARCH_MIN_SCORE=40
PM_ROBOT_RESEARCH_BUSY_TIMEOUT_SECONDS=15
PM_ROBOT_RESEARCH_PLANNER_LOCK_ATTEMPTS=4
PM_ROBOT_RESEARCH_PLANNER_LOCK_SLEEP_SECONDS=1
PM_ROBOT_PIPELINE_SHARD_COUNT=3
PM_ROBOT_PIPELINE_STATE_LIMIT=25
PM_ROBOT_PIPELINE_STATE_COMMIT_EVERY=5
PM_ROBOT_PIPELINE_PLANNER_LIGHT_LIMIT=30
PM_ROBOT_PIPELINE_PLANNER_MEDIUM_LIMIT=20
PM_ROBOT_PIPELINE_PLANNER_DEEP_LIMIT=5
PM_ROBOT_PIPELINE_PLANNER_MAX_ACTIVE_JOBS=240
PM_ROBOT_ELIGIBILITY_REPAIR_LIMIT=100
PM_ROBOT_PIPELINE_WORKER_INTERVAL=60
PM_ROBOT_PIPELINE_WORKER_LIMIT=6
PM_ROBOT_PIPELINE_WORKER_PAGE_LIMIT=120
PM_ROBOT_PIPELINE_WORKER_SLEEP=0.05
PM_ROBOT_PIPELINE_WORKER_LEASE_SECONDS=900
PM_ROBOT_PIPELINE_PRIORITY_AGING_SECONDS=1800

# Dedicated copyability evidence queue admission and worker limits.
PM_ROBOT_COPYABILITY_SHARD_COUNT=1
PM_ROBOT_COPYABILITY_PLANNER_LIMIT=50
PM_ROBOT_COPYABILITY_PLANNER_MAX_ACTIVE_JOBS=50
PM_ROBOT_COPYABILITY_MIN_ACTIVITY_EVENTS=25
PM_ROBOT_COPYABILITY_RESCAN_SECONDS=21600
PM_ROBOT_COPYABILITY_WORKER_INTERVAL=30
PM_ROBOT_COPYABILITY_WORKER_LIMIT=1
PM_ROBOT_COPYABILITY_WORKER_LEASE_SECONDS=7200
PM_ROBOT_COPYABILITY_MAX_LEADER_EVENTS=3000
PM_ROBOT_COPYABILITY_MAX_FOLLOWERS_PER_EVENT=200

# High-quality discovery loop: official category leaderboards + whale-size trades.
PM_ROBOT_DISCOVERY_LOOP_INTERVAL=3600
PM_ROBOT_DISCOVERY_LEADERBOARD_METRICS=
PM_ROBOT_DISCOVERY_LEADERBOARD_WINDOWS=
PM_ROBOT_DISCOVERY_LEADERBOARD_CATEGORIES=OVERALL,POLITICS,SPORTS,CRYPTO
PM_ROBOT_DISCOVERY_LEADERBOARD_TIME_PERIODS=WEEK,MONTH
PM_ROBOT_DISCOVERY_LEADERBOARD_ORDER_BYS=PNL,VOL
PM_ROBOT_DISCOVERY_LEADERBOARD_V1_LIMIT=50
PM_ROBOT_DISCOVERY_LEADERBOARD_V1_PAGES=1
PM_ROBOT_DISCOVERY_ACTIVITY_PAGES=3
PM_ROBOT_DISCOVERY_ACTIVITY_PAGE_LIMIT=100
PM_ROBOT_DISCOVERY_ACTIVITY_MIN_TRADE_FILTER_USDC=500
PM_ROBOT_DISCOVERY_ACTIVITY_MAX_CANDIDATES=150
PM_ROBOT_DISCOVERY_ACTIVITY_SLEEP=0.05

# Real-time activity trade stream. Keeps discovery event-driven between polling cycles.
PM_ROBOT_RTDS_ENDPOINT=wss://ws-live-data.polymarket.com
PM_ROBOT_RTDS_MIN_TRADE_USDC=500
PM_ROBOT_RTDS_PAPER_MIN_TRADE_USDC=0
PM_ROBOT_RTDS_WATCH_MIN_SCORE=65
PM_ROBOT_RTDS_BATCH_SIZE=20
PM_ROBOT_RTDS_FLUSH_INTERVAL=10
PM_ROBOT_RTDS_PING_INTERVAL=5
PM_ROBOT_RTDS_RECEIVE_TIMEOUT=1
PM_ROBOT_RTDS_RECONNECT_SLEEP=5
PM_ROBOT_RTDS_MAX_RUNTIME_SECONDS=0
PM_ROBOT_RTDS_MAX_RECONNECTS=0

# Incremental feature/scoring phase inside the ordered research control cycle.
PM_ROBOT_SCORE_FEATURE_LIMIT=80
PM_ROBOT_SCORE_FEATURE_COMMIT_EVERY=10
PM_ROBOT_SCORE_LIMIT=300
PM_ROBOT_SCORE_MIN_ACTIVITY_EVENTS=25
PM_ROBOT_EVIDENCE_PROMOTION_LIMIT=80
PM_ROBOT_PAPER_HANDOFF_LIMIT=250

# Fast read-only paper observer loop. It keeps paper-stage wallet activity and
# quote/actionability evidence fresh without creating paper orders or publishing.
PM_ROBOT_PAPER_OBSERVER_LOOP_INTERVAL=60
PM_ROBOT_PAPER_OBSERVER_PREVIEW_LIMIT=50
PM_ROBOT_PAPER_OBSERVER_ACTIVITY_WALLET_LIMIT=10
PM_ROBOT_PAPER_OBSERVER_ACTIVITY_PAGE_LIMIT=50
PM_ROBOT_PAPER_OBSERVER_ACTIVITY_MAX_EVENTS=50
PM_ROBOT_PAPER_OBSERVER_ACTIVITY_SLEEP=0.1
PM_ROBOT_PAPER_ACTIVITY_WALLET_LIMIT=10
PM_ROBOT_PAPER_ACTIVITY_PAGE_LIMIT=50
PM_ROBOT_PAPER_ACTIVITY_MAX_EVENTS=50
PM_ROBOT_PAPER_ACTIVITY_SLEEP=0.1
PM_ROBOT_PAPER_OBSERVER_MAX_SIGNAL_AGE_SEC=21600
PM_ROBOT_PAPER_OBSERVER_MAX_ACTIONABLE_SIGNAL_AGE_SEC=300
PM_ROBOT_PAPER_OBSERVER_EVALUATION_MAX_SIGNAL_AGE_SEC=300
PM_ROBOT_PAPER_OBSERVER_EVALUATION_LIMIT=25
PM_ROBOT_PAPER_OBSERVER_MAX_STAKE_USD=40

# Opt-in execution profile defaults. These are ignored by the default
# research/scoring stack unless `./pmrobot-nas.sh execution-up` is run.
PM_ROBOT_PAPER_RUN_LOOP_INTERVAL=60
PM_ROBOT_PAPER_RUN_LIMIT=50
PM_ROBOT_PAPER_RUN_MAX_STAKE_USD=40
PM_ROBOT_PAPER_RUN_MAX_SIGNAL_AGE_SEC=300
PM_ROBOT_PAPER_RUN_LOCK_WAIT=120
PM_ROBOT_PAPER_SETTLE_LOOP_INTERVAL=900
PM_ROBOT_PAPER_SETTLE_LOCK_WAIT=120
PM_ROBOT_PUBLISH_LOOP_INTERVAL=900
PM_ROBOT_PUBLISH_TTL_SECONDS=86400
PM_ROBOT_PUBLISH_LOCK_WAIT=120
PM_ROBOT_PUBLISHED_LEADERS_PATH=/app/reports/published_leaders.json
PM_ROBOT_WRITE_LOCK_PATH=/app/data/pm_robot.write.lock

# Passive checkpoint keeps allocated WAL space reusable without stopping writers.
# Physical shrinking remains an explicit low-traffic maintenance command.
PM_ROBOT_MAINTENANCE_INTERVAL=900
PM_ROBOT_MAINTENANCE_START_DELAY=300
PM_ROBOT_MAINTENANCE_WAL_CHECKPOINT=passive
PM_ROBOT_MAINTENANCE_REPORT_PATH=/app/reports/maintenance_status.json
PM_ROBOT_MAINTENANCE_STALE_INGEST_RUN_SECONDS=21600
PM_ROBOT_MAINTENANCE_FAILED_JOB_COOLDOWN_SECONDS=21600
PM_ROBOT_MAINTENANCE_RUNTIME_HEARTBEAT_DAYS=30
PM_ROBOT_MAINTENANCE_CLEANUP_BATCH_LIMIT=500
PM_ROBOT_RETENTION_PRUNE_ENABLED=1
PM_ROBOT_RETENTION_PRUNE_BATCHES=1
PM_ROBOT_RETENTION_PRUNE_LIMIT=20
PM_ROBOT_RETENTION_PRUNE_MAX_ACTIVITY_ROWS=5000
PM_ROBOT_RETENTION_PRUNE_BATCH_DELAY=10
PM_ROBOT_RETENTION_KEEP_RECENT_ACTIVITY=0
PM_ROBOT_RETENTION_ARCHIVE_ENABLED=0
PM_ROBOT_RETENTION_PRUNE_REPORT_PATH=/app/reports/retention_prune_status.json
PM_ROBOT_ARCHIVE_DIR=/app/data/parquet
