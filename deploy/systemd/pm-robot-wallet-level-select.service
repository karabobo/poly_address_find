[Unit]
Description=pm-robot policy-versioned relative L3-L5 selection
After=network-online.target

[Service]
Type=oneshot
WorkingDirectory=/opt/pm-robot
EnvironmentFile=/opt/pm-robot/.env
TimeoutStartSec=120
Environment=PM_ROBOT_LOCK_WAIT=60
Environment=PM_ROBOT_TASK_NAME=wallet-level-select
ExecStart=/opt/pm-robot/deploy/scripts/run_locked.sh /opt/pm-robot/.venv/bin/python -m pm_robot.cli --env /opt/pm-robot/.env wallet-level-select --min-cohort-size 20 --max-wait-seconds 3600
